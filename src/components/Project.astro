---
import type { CollectionEntry } from "astro:content";

type Props = CollectionEntry<"projects">;

const { data, slug } = Astro.props;

const { title, description, tags, vibeCoded } = data;
---

<a href={`/projects/${slug}/`} class="flex h-48">
  <div
    class="flex w-full bg-white hover:shadow-lg shadow-md rounded-lg overflow-hidden"
  >
    <div class="w-1/3">
      <div class="h-full w-full relative overflow-hidden">
        <img
          src={`/img/projects/${slug}/thumbnail.png`}
          alt={title}
          class="min-h-full min-w-full object-cover"
        />
      </div>
    </div>

    <div class="w-2/3 p-4 md:p-4">
      <div class="flex items-center flex-wrap gap-2">
        <h3 class="text-gray-900 font-bold text-xl">
          {title}
        </h3>
        {
          vibeCoded && (
            <span
              title="This project was vibe coded: built largely with the help of AI coding assistants."
              class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-purple-100 text-purple-700"
            >
              <svg
                class="w-3 h-3 mr-1"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-6.714 2.143L12 21l-2.286-6.857L3 12l6.714-2.143L12 3z"
                />
              </svg>
              Vibe coded
            </span>
          )
        }
      </div>

      <p class="mt-2 text-gray-600 text-sm">
        {description}
      </p>

      <div class="flex item-center mt-2">
        {
          (tags ?? []).map((tag: string) => (
            <span class="text-gray-900 font-semibold mr-2">#{tag}</span>
          ))
        }
      </div>
    </div>
  </div>
</a>
